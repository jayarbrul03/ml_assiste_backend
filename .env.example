# AV Labeling Platform — local (no Docker)

DATABASE_URL=sqlite+aiosqlite:///./data/avplatform.db
STORAGE_BACKEND=local
LOCAL_FILES_URL=http://localhost:8000/files
JWT_SECRET=dev-secret-change-in-production
CORS_ORIGINS=http://localhost:3000
# Set true to wipe and re-seed demo data on every API start (dev only)
DB_RESET_ON_START=false
