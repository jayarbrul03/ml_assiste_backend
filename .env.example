# AV Labeling Platform — copy to .env and fill in values

DATABASE_URL=sqlite+aiosqlite:///./data/avplatform.db
STORAGE_BACKEND=local
LOCAL_FILES_URL=http://localhost:8000/files
JWT_SECRET=change-me-to-a-long-random-string
CORS_ORIGINS=http://localhost:3000
COOKIE_SECURE=false
DB_RESET_ON_START=false

OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4o
AUTOLABEL_ENABLED=true
AUTOLABEL_CONFIDENCE_THRESHOLD=0.85
AUTOLABEL_AUTO_SUBMIT=true
ACTIVE_LEARNING_UNCERTAINTY_THRESHOLD=0.3
